{
  "name": "react-video-wall",
  "version": "0.0.0",
  "description": "Composable React component library for video-wall (大屏) layout, windowing, and interactive editing. Zero-dep core with lossless physical-integer coordinates.",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/core.js",
  "module": "./dist/core.js",
  "types": "./dist/core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./interactive": {
      "types": "./dist/interactive.d.ts",
      "import": "./dist/interactive.js"
    },
    "./style.css": "./dist/rvw.css"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "release-it"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "@vitest/coverage-v8": "^3",
    "happy-dom": "^20",
    "react": "^19",
    "react-dom": "^19",
    "react-rnd": "^10.5.3",
    "typescript": "^5",
    "vite": "^8",
    "vite-plugin-dts": "^4",
    "vitest": "^3"
  },
  "peerDependencies": {
    "react": ">=17.0.2",
    "react-dom": ">=17.0.2",
    "react-rnd": ">=10"
  }
}
